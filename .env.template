# Template for the Maestree auth server config. Copy to .env and fill in:
#   cp .env.template .env
# .env holds real secrets (DB password + private signing seed); it is gitignored
# and must NEVER be committed. This template is safe to commit — placeholders only.

# Postgres — use a STRONG, ALPHANUMERIC password (no @ : / # ? so the DSN is clean).
POSTGRES_USER=maestree
POSTGRES_PASSWORD=CHANGE_ME_strong_alphanumeric
POSTGRES_DB=maestree

# Domain Caddy serves over HTTPS (its DNS A record must point to this server).
AUTH_DOMAIN=auth.example.com

# Ed25519 signing key: base64 of a 32-byte seed. Generate a FRESH one per deploy
# (on the server — never reuse this placeholder), then back it up securely:
#   head -c32 /dev/urandom | base64
# If this ever changes, all existing tokens/sessions become invalid.
AUTH_ED25519_SEED=CHANGE_ME_generate_with_head_-c32_/dev/urandom_base64

# Token lifetimes (optional; defaults shown).
ACCESS_TTL=168h
REFRESH_TTL=720h
